# Application Environment
APP_ENV=development

# Go API Service
GO_API_PORT=8080

# Python Service (FastAPI + WhisperX)
PYTHON_SERVICE_PORT=8000
DEVICE=cuda

# Frontend Service
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:8080

# PostgreSQL Database
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=asr_db

# Redis Cache & Queue
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
